# Provider IA utilisé par /api/generate-trip
# Valeurs possibles : gemini ou openai
AI_PROVIDER=gemini

# Gemini — côté serveur uniquement
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-2.5-flash

# OpenAI — côté serveur uniquement, optionnel pour plus tard
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4.1-mini
